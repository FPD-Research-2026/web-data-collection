# Web Data Collection App — Configuration
# Updated: 2026-03-29
#
# Fill in your values below, then run:  bash configure.sh
#

# --- Google Cloud Platform ---

# Your GCP project ID (e.g., "my-research-project-123456")
GCP_PROJECT_ID=

# Service account name — just the part before the @ (e.g., "my-data-sa")
# The full email will be: <name>@<project-id>.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT=

# Cloud Storage bucket name for receiving uploaded data (e.g., "my-research-data-bucket")
GCS_BUCKET=

# --- Hosting ---

# Your GitHub Pages URL or other hosting base URL — NO trailing slash
# (e.g., "https://myorg.github.io/my-repo")
GITHUB_PAGES_URL=

# --- Cloud Function ---

# Your deployed Cloud Function URL (fill in AFTER deploying — see README Step 3)
# (e.g., "https://us-east1-my-research-project-123456.cloudfunctions.net/saver")
CLOUD_FUNCTION_URL=

# --- Study Details ---

# Study name shown on the landing and consent pages (e.g., "Typing Dynamics Study")
STUDY_NAME=

# Longer study description shown on the completion receipt (e.g., "Multimodal Typing Dynamics Research")
STUDY_DESCRIPTION=

# Institution name shown on the completion receipt (e.g., "University of Example")
INSTITUTION_NAME=

# --- Optional ---

# Researcher contact email shown to participants on the survey-code page
# (e.g., "yourlab@university.edu")
RESEARCHER_EMAIL=

# Validation API URL for MTurk completion code verification
# Leave blank if not using MTurk, or set to your own validation endpoint
VALIDATION_API_URL=
